pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: page-title
    elementType: text
    bounds: [60, 40, 900, 40]
    content:
      style: "$pageTitle"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Guide de Deploiement sur Serveur</strong></p>
  - elementId: title-line
    elementType: shape
    bounds: [60, 85, 100, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 3, color: "$accent"}
  - elementId: prereq-label
    elementType: text
    bounds: [60, 105, 300, 25]
    content:
      fontSize: 14
      color: "$accent"
      fontFamily: "Liter"
      letterSpacing: 2
      wrap: false
      text: |
        <p><strong>PRE-REQUIS</strong></p>
  - elementId: prereq-text
    elementType: text
    bounds: [60, 130, 1160, 22]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter"
      text: |
        <p>Node.js 20+  |  MySQL 8+  |  Compte Kimi OAuth  |  Git</p>
  - elementId: step1-bg
    elementType: shape
    bounds: [60, 170, 370, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$white"
    border: {style: solid, width: 1, color: "$light"}
  - elementId: step1-num
    elementType: text
    bounds: [75, 180, 40, 35]
    content:
      fontSize: 28
      color: "$primary"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>1</strong></p>
  - elementId: step1-title
    elementType: text
    bounds: [120, 182, 290, 28]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p><strong>Cloner &amp; Installer</strong></p>
  - elementId: step1-code
    elementType: text
    bounds: [75, 220, 340, 130]
    content:
      fontSize: 13
      color: "$secondary"
      fontFamily: "Liter"
      lineHeight: 1.6
      text: |
        <p><span style="color:#7C3AED;">git clone</span> &lt;repo&gt;</p>
        <p><span style="color:#7C3AED;">cd</span> cartographie-app</p>
        <p><span style="color:#7C3AED;">npm install</span></p>
        <p><span style="font-size:12px; color:#9CA3AF;"># Installe toutes les dependances</span></p>
  - elementId: step2-bg
    elementType: shape
    bounds: [455, 170, 370, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$white"
    border: {style: solid, width: 1, color: "$light"}
  - elementId: step2-num
    elementType: text
    bounds: [470, 180, 40, 35]
    content:
      fontSize: 28
      color: "$primary"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>2</strong></p>
  - elementId: step2-title
    elementType: text
    bounds: [515, 182, 290, 28]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p><strong>Configurer .env</strong></p>
  - elementId: step2-code
    elementType: text
    bounds: [470, 220, 340, 130]
    content:
      fontSize: 13
      color: "$secondary"
      fontFamily: "Liter"
      lineHeight: 1.6
      text: |
        <p><span style="color:#1E3A5F;">DATABASE_URL</span>=mysql://...</p>
        <p><span style="color:#1E3A5F;">VITE_APP_ID</span>= votre_app_id</p>
        <p><span style="color:#1E3A5F;">VITE_KIMI_AUTH_URL</span>=...</p>
        <p><span style="color:#1E3A5F;">SESSION_SECRET</span>=...</p>
  - elementId: step3-bg
    elementType: shape
    bounds: [850, 170, 370, 200]
    shapeName: rect
    fill:
      type: solid
      color: "$white"
    border: {style: solid, width: 1, color: "$light"}
  - elementId: step3-num
    elementType: text
    bounds: [865, 180, 40, 35]
    content:
      fontSize: 28
      color: "$primary"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>3</strong></p>
  - elementId: step3-title
    elementType: text
    bounds: [910, 182, 290, 28]
    content:
      fontSize: 16
      color: "$text"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p><strong>Base de Donnees</strong></p>
  - elementId: step3-code
    elementType: text
    bounds: [865, 220, 340, 130]
    content:
      fontSize: 13
      color: "$secondary"
      fontFamily: "Liter"
      lineHeight: 1.6
      text: |
        <p><span style="color:#7C3AED;">npm run db:push</span></p>
        <p><span style="font-size:12px; color:#9CA3AF;"># Cree les 5 tables</span></p>
        <p><span style="color:#7C3AED;">npm run db:seed</span></p>
        <p><span style="font-size:12px; color:#9CA3AF;"># Donnees de demo (opt.)</span></p>
  - elementId: step4-bg
    elementType: shape
    bounds: [60, 395, 560, 130]
    shapeName: rect
    fill:
      type: solid
      color: "$primary"
  - elementId: step4-num
    elementType: text
    bounds: [75, 405, 40, 35]
    content:
      fontSize: 28
      color: "$white"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>4</strong></p>
  - elementId: step4-title
    elementType: text
    bounds: [120, 407, 290, 28]
    content:
      fontSize: 16
      color: "$white"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p><strong>Builder</strong></p>
  - elementId: step4-code
    elementType: text
    bounds: [75, 445, 530, 60]
    content:
      fontSize: 14
      color: "#FFFFFFCC"
      fontFamily: "Liter"
      lineHeight: 1.6
      text: |
        <p><span style="color:#4ADE80;">npm run build</span>  <span style="font-size:12px;"># Build frontend + backend</span></p>
        <p><span style="font-size:12px;"># Sortie dans dist/ (frontend) + api/ (backend)</span></p>
  - elementId: step5-bg
    elementType: shape
    bounds: [660, 395, 560, 130]
    shapeName: rect
    fill:
      type: solid
      color: "$accent"
  - elementId: step5-num
    elementType: text
    bounds: [675, 405, 40, 35]
    content:
      fontSize: 28
      color: "$dark"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>5</strong></p>
  - elementId: step5-title
    elementType: text
    bounds: [720, 407, 290, 28]
    content:
      fontSize: 16
      color: "$dark"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p><strong>Demarrer en Production</strong></p>
  - elementId: step5-code
    elementType: text
    bounds: [675, 445, 530, 60]
    content:
      fontSize: 14
      color: "$dark"
      fontFamily: "Liter"
      lineHeight: 1.6
      text: |
        <p><strong>npm start</strong>  <span style="font-size:12px;"># Serveur sur port 3000</span></p>
        <p><span style="font-size:12px;"># Frontend : localhost:3000 | API : /api/trpc</span></p>
  - elementId: note
    elementType: text
    bounds: [60, 550, 1160, 80]
    content:
      fontSize: 15
      color: "$text"
      fontFamily: "Liter"
      lineHeight: 1.6
      text: |
        <p><strong style="color:#1E3A5F;">Commandes utiles :</strong></p>
        <p><span style="color:#6B7280;">npm run dev</span> — Mode developpement avec HMR | <span style="color:#6B7280;">npm run check</span> — Verification TypeScript | <span style="color:#6B7280;">npm run db:generate</span> — Generation de migrations</p>
  - elementId: bottom-line
    elementType: shape
    bounds: [60, 660, 1160, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "$light"}
  - elementId: page-num
    elementType: text
    bounds: [1150, 670, 70, 20]
    content:
      fontSize: 12
      color: "$secondary"
      fontFamily: "Liter"
      align: [right, middle]
      wrap: false
      text: "15"
