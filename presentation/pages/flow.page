      color: "$text"
      fontFamily: "Liter"
      align: [center, middle]
      text: |
        <p><strong>MySQL 8</strong></p>
        <p><span style="font-size:10px; color:$secondary;">Donnees metier relationnelles</span></p>
  - elementId: layer3-box2
    elementType: shape
