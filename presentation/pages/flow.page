    bounds: [800, 346, 420, 60]
    content:
      fontSize: 12
      color: "$text"
      fontFamily: "Liter"
      lineHeight: 1.5
      text: |
        <p>Firebase SDK sync <strong>en arriere-plan</strong> localStorage vers Firestore. Operation <strong>bidirectionnelle</strong> et <strong>asynchrone</strong> — ne bloque pas l'API principale.</p>

  # ===== BOTTOM — RELATIONS EXPLANATIONS =====
  - elementId: bottom-title
    elementType: text
    bounds: [60, 480, 400, 22]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "Liter"
