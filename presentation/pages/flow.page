      color: "$primary"
  - elementId: flow1-badge-text
    elementType: text
    bounds: [800, 142, 90, 20]
    content:
      fontSize: 10
      color: "$white"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>FLOW API</strong></p>
