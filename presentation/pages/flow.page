    elementType: text
    bounds: [800, 166, 420, 60]
    content:
      fontSize: 12
      color: "$text"
      fontFamily: "Liter"
      lineHeight: 1.5
      text: |
        <p><strong>Appel tRPC</strong> → Client serialise → Hono recoit → RBAC verifie → Drizzle SQL → MySQL retourne les donnees.</p>

