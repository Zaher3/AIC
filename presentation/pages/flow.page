  - elementId: flow3-badge
    elementType: shape
    bounds: [800, 322, 100, 20]
    shapeName: rect
    fill:
      type: solid
      color: "#F59E0B"
  - elementId: flow3-badge-text
    elementType: text
    bounds: [800, 322, 100, 20]
    content:
      fontSize: 10
      color: "$white"
      fontFamily: "Liter"
