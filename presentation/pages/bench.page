  # ===== BOTTOM INSIGHTS =====
  - elementId: insight-title
    elementType: text
    bounds: [60, 540, 400, 22]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "Liter"
      letterSpacing: 1
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>ANALYSE COMPARATIVE</strong></p>
  - elementId: insight-line
    elementType: shape
    bounds: [60, 565, 1160, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "$light"}

  # Left insight
  - elementId: insight-left
    elementType: text
    bounds: [60, 575, 370, 68]
    content:
      fontSize: 11
      color: "$text"
      fontFamily: "Liter"
      lineHeight: 1.5
      text: |
        <p><strong style="color:#1E3A5F;">Solutions existantes</strong> : Odoo et SAP Ariba gerent les AO mais sont lourds et couteux. Monday et Notion sont agiles mais manquent le workflow metier specifique aux consultations.</p>

  - elementId: insight-center
    elementType: text
    bounds: [455, 575, 370, 68]
    content:
      fontSize: 11
      color: "$text"
      fontFamily: "Liter"
      lineHeight: 1.5
      text: |
        <p><strong style="color:#1E3A5F;">Gap identifie</strong> : Aucune solution ne combine (1) gestion de consultation avec workflow en 14 etapes, (2) RBAC par equipe avec directeur, et (3) stockage hierarchique Entreprise > Projet > Etape > Fichier.</p>

  - elementId: insight-right
    elementType: text
    bounds: [850, 575, 370, 68]
    content:
      fontSize: 11
      color: "$text"
      fontFamily: "Liter"
      lineHeight: 1.5
      text: |
        <p><strong style="color:#1E3A5F;">Positionnement</strong> : Le prototype couvre exactement ce gap avec une interface simple pour le service commercial, un cout nul (open source) et un deploiement leger sur serveur interne.</p>

  # ===== FOOTER =====
  - elementId: bottom-line
    elementType: shape
    bounds: [60, 660, 1160, 0]
