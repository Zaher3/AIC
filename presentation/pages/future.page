pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: page-title
    elementType: text
    bounds: [60, 40, 900, 40]
    content:
      style: "$pageTitle"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Perspectives d'Evolution</strong></p>
  - elementId: title-line
    elementType: shape
    bounds: [60, 85, 100, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 3, color: "$accent"}
  - elementId: f1-bg
    elementType: shape
    bounds: [60, 115, 370, 165]
    shapeName: rect
    fill:
      type: solid
      color: "$white"
    border: {style: solid, width: 1, color: "$light"}
  - elementId: f1-icon
    elementType: icon
    bounds: [80, 130, 28, 28]
    iconName: "fas:bell"
    fill:
      type: solid
      color: "$accent"
  - elementId: f1-title
    elementType: text
    bounds: [80, 168, 330, 26]
    content:
      fontSize: 17
      color: "$text"
      fontFamily: "Liter"
      wrap: false
      text: |
        <p><strong>Notifications Temps Reel</strong></p>
  - elementId: f1-desc
    elementType: text
    bounds: [80, 198, 330, 68]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter"
      lineHeight: 1.5
      text: |
        <p>Alertes pour demandes d'acces, modifications de documents, changements de statut de projet.</p>
  - elementId: f2-bg
    elementType: shape
    bounds: [455, 115, 370, 165]
    shapeName: rect
    fill:
      type: solid
      color: "$white"
    border: {style: solid, width: 1, color: "$light"}
  - elementId: f2-icon
