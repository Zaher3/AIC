pageType: cover
background:
  type: solid
  color: "$dark"
elements:
  - elementId: accent-line
    elementType: shape
    bounds: [540, 280, 200, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 2, color: "$accent"}
  - elementId: title
    elementType: text
    bounds: [90, 180, 1100, 80]
    content:
      style: "$title"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>CARTOGRAPHIE INTERACTIVE</strong></p>
  - elementId: subtitle
    elementType: text
    bounds: [190, 300, 900, 35]
    content:
      fontSize: 20
      color: "$light"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p>Systeme de Gestion Collaborative des Consultations et Appels d'Offres</p>
  - elementId: tagline
    elementType: text
    bounds: [340, 360, 600, 25]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p>Prototype &amp; Architecture Technique  |  Service Commercial &amp; Estimation des Couts</p>
  - elementId: bottom-line
    elementType: shape
    bounds: [60, 660, 1160, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "#334155"}
