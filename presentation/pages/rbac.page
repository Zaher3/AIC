pageType: content
background:
  type: solid
  color: "$background"
elements:
  # ===== TITLE =====
  - elementId: page-title
    elementType: text
    bounds: [60, 40, 1100, 40]
    content:
      style: "$pageTitle"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>Matrice de Permissions — Organisation a 2 Equipes</strong></p>
  - elementId: title-line
    elementType: shape
    bounds: [60, 85, 100, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 3, color: "$accent"}

  # ===== ORG STRUCTURE MINI DIAGRAM =====
  - elementId: org-dir-box
    elementType: shape
    bounds: [60, 100, 200, 40]
    shapeName: rect
    fill:
      type: solid
      color: "#DC2626"
  - elementId: org-dir-text
    elementType: text
    bounds: [60, 100, 200, 40]
    content:
      fontSize: 13
      color: "$white"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>Directeur Service</strong></p>
  - elementId: org-arrow1
    elementType: shape
    bounds: [140, 140, 0, 18]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border: {style: solid, width: 2, color: "$secondary"}
  - elementId: org-arrow2
    elementType: shape
    bounds: [280, 140, 0, 18]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border: {style: solid, width: 2, color: "$secondary"}
  - elementId: org-line-h
    elementType: shape
    bounds: [140, 140, 140, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 2, color: "$secondary"}
  - elementId: org-resp1-box
    elementType: shape
    bounds: [60, 158, 160, 36]
    shapeName: rect
    fill:
      type: solid
      color: "#7C3AED"
  - elementId: org-resp1-text
    elementType: text
    bounds: [60, 158, 160, 36]
    content:
      fontSize: 11
      color: "$white"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>Responsable Eq. 1</strong></p>
  - elementId: org-resp2-box
    elementType: shape
    bounds: [240, 158, 160, 36]
    shapeName: rect
    fill:
      type: solid
      color: "#7C3AED"
  - elementId: org-resp2-text
    elementType: text
    bounds: [240, 158, 160, 36]
    content:
      fontSize: 11
      color: "$white"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p><strong>Responsable Eq. 2</strong></p>
  - elementId: org-mem1-label
    elementType: text
    bounds: [60, 198, 160, 18]
    content:
      fontSize: 10
      color: "$secondary"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p>Membres Eq. 1</p>
  - elementId: org-mem2-label
    elementType: text
    bounds: [240, 198, 160, 18]
    content:
      fontSize: 10
      color: "$secondary"
      fontFamily: "Liter"
      align: [center, middle]
      wrap: false
      text: |
        <p>Membres Eq. 2</p>

  # ===== LEGEND (right of org chart) =====
  - elementId: legend-title
    elementType: text
    bounds: [450, 100, 300, 22]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "Liter"
      letterSpacing: 1
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>LEGENDE</strong></p>
  - elementId: legend-green
    elementType: shape
    bounds: [450, 128, 12, 12]
    shapeName: rect
    fill:
      type: solid
      color: "#4ADE80"
  - elementId: legend-green-text
    elementType: text
    bounds: [468, 125, 80, 18]
    content:
      fontSize: 11
      color: "$secondary"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: |
        <p>Autorise</p>
  - elementId: legend-yellow
    elementType: shape
    bounds: [560, 128, 12, 12]
    shapeName: rect
    fill:
      type: solid
      color: "#F59E0B"
  - elementId: legend-yellow-text
    elementType: text
    bounds: [578, 125, 110, 18]
    content:
      fontSize: 11
      color: "$secondary"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: |
        <p>Sur autorisation</p>
  - elementId: legend-red
    elementType: shape
    bounds: [700, 128, 12, 12]
    shapeName: rect
    fill:
      type: solid
      color: "#EF4444"
  - elementId: legend-red-text
    elementType: text
    bounds: [718, 125, 80, 18]
    content:
      fontSize: 11
      color: "$secondary"
      fontFamily: "Liter"
      align: [left, middle]
      wrap: false
      text: |
        <p>Interdit</p>
  - elementId: legend-scope
    elementType: text
    bounds: [450, 150, 770, 60]
    content:
      fontSize: 11
      color: "$text"
      fontFamily: "Liter"
      lineHeight: 1.5
      text: |
        <p><strong>Directeur</strong> : visualise tous les projets des 2 equipes. <strong>Responsable</strong> : visualise et modifie les projets de son equipe. <strong>Membre</strong> : ne visualise que ses projets et ceux partages avec lui.</p>

  # ===== RBAC TABLE =====
  - elementId: rbac-table
    elementType: table
    bounds: [60, 226, 1160, 370]
    columnWidths: [0.22, 0.17, 0.17, 0.17, 0.14, 0.13]
    rowHeights: [0.1, 0.15, 0.15, 0.15, 0.15, 0.15, 0.15]
    style: "$default"
    rows:
      - - content:
            text: |
              <p><strong>Action</strong></p>
        - content:
            text: |
              <p><strong>Directeur</strong></p>
          fill:
            type: solid
            color: "#DC262620"
        - content:
            text: |
              <p><strong>Resp. Eq.1</strong></p>
          fill:
            type: solid
            color: "#7C3AED20"
        - content:
            text: |
              <p><strong>Resp. Eq.2</strong></p>
          fill:
            type: solid
            color: "#7C3AED20"
        - content:
            text: |
              <p><strong>Membre</strong></p>
          fill:
            type: solid
            color: "#1E3A5F15"
        - content:
            text: |
              <p><strong>Scope</strong></p>
          fill:
            type: solid
            color: "#F59E0B15"
      - - content:
            text: |
              <p><strong>Visualiser projets</strong></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;"><strong>Tous (2 eq.)</strong></span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;"><strong>Eq.1</strong></span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;"><strong>Eq.2</strong></span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;">Ses projets + partages</span></p>
        - content:
            text: |
              <p><span style="font-size:12px;">Toute l'entreprise</span></p>
      - - content:
            text: |
              <p><strong>Modifier documents</strong></p>
        - content:
            text: |
              <p><span style="color:#F59E0B;">Sur autorisation owner</span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;"><strong>Projets Eq.1</strong></span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;"><strong>Projets Eq.2</strong></span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;">Ses propres projets</span></p>
        - content:
            text: |
              <p><span style="font-size:12px;">Equipe limitee</span></p>
      - - content:
            text: |
              <p><strong>Partager / inviter</strong></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;"><strong>Oui</strong></span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;"><strong>Eq.1</strong></span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;"><strong>Eq.2</strong></span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;">Si owner</span></p>
        - content:
            text: |
              <p><span style="font-size:12px;">Equipe + inter-equipes</span></p>
      - - content:
            text: |
              <p><strong>Supprimer projet</strong></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;"><strong>Oui</strong></span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;">Projets Eq.1</span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;">Projets Eq.2</span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;">Si owner</span></p>
        - content:
            text: |
              <p><span style="font-size:12px;">Selon hierarchie</span></p>
      - - content:
            text: |
              <p><strong>Autoriser edition</strong></p>
        - content:
            text: |
              <p><span style="color:#F59E0B;">Demande au owner</span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;">Donne a Eq.1</span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;">Donne a Eq.2</span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;">Donne a contacts</span></p>
        - content:
            text: |
              <p><span style="font-size:12px;">Flow descendant</span></p>
      - - content:
            text: |
              <p><strong>Acces fichiers</strong></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;"><strong>Tous</strong></span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;">Eq.1</span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;">Eq.2</span></p>
        - content:
            text: |
              <p><span style="color:#4ADE80;">Projets accessibles</span></p>
        - content:
            text: |
              <p><span style="font-size:12px;">Herite projets</span></p>

  # ===== FLOW DESCRIPTION =====
  - elementId: flow-label
    elementType: text
    bounds: [60, 608, 300, 20]
    content:
      fontSize: 12
      color: "$accent"
      fontFamily: "Liter"
      letterSpacing: 1
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>FLOW D'AUTORISATION</strong></p>
  - elementId: flow-desc
    elementType: text
    bounds: [60, 630, 1160, 24]
    content:
      fontSize: 11
      color: "$text"
      fontFamily: "Liter"
      lineHeight: 1.4
      text: |
        <p>Le <strong>Directeur</strong> visualise tout mais doit demander l'autorisation au <strong>owner</strong> pour modifier. Chaque <strong>Responsable</strong> gere son equipe et peut donner acces aux membres. Les <strong>Membres</strong> ne voient que leurs projets sauf autorisation explicite.</p>

  # ===== FOOTER =====
  - elementId: bottom-line
    elementType: shape
    bounds: [60, 660, 1160, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 1, color: "$light"}
  - elementId: page-num
    elementType: text
    bounds: [1150, 670, 70, 20]
    content:
      fontSize: 12
      color: "$secondary"
      fontFamily: "Liter"
      align: [right, middle]
      wrap: false
      text: "12"